{
  "name": "spectra-sdd",
  "version": "0.1.0",
  "description": "SPECTRA — Spec-Templated Execution with Composable Traceability and Reconciliation Architecture",
  "type": "module",
  "bin": {
    "spectra": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit",
    "spectra": "tsx src/cli/index.ts"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "yaml": "^2.7.1",
    "zod": "^3.24.4",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "keywords": [
    "spec-driven-development",
    "sdd",
    "spectra",
    "specification",
    "traceability",
    "drift-detection"
  ],
  "license": "MIT"
}
