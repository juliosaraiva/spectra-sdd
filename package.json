{
  "name": "spectra-sdd",
  "version": "0.1.0",
  "description": "SPECTRA — Spec-Templated Execution with Composable Traceability and Reconciliation Architecture",
  "type": "module",
  "bin": {
    "spectra": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "prepare": "(husky || true) && npm run build",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "spectra": "tsx src/cli/index.ts",
    "release:dry": "npx semantic-release --dry-run"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "handlebars": "^4.7.8",
    "yaml": "^2.7.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/node": "^22.15.3",
    "@vitest/coverage-v8": "^3.2.4",
    "conventional-changelog-conventionalcommits": "^9.3.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "tsup": "^8.4.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.57.1",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "templates",
    "scaffolds"
  ],
  "keywords": [
    "spec-driven-development",
    "sdd",
    "spectra",
    "specification",
    "traceability",
    "drift-detection"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/juliosaraiva/spectra-sdd.git"
  },
  "license": "MIT",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ]
  }
}
